#!/bin/bash
# Install oh-my-claude plugin
# https://github.com/TechDufus/oh-my-claude

set -e

# Get the script root directory
CS_ROOT="${CS_ROOT:-$HOME/claude-config-sync}"

# Source common utilities
# shellcheck source=lib/common.sh
if [[ -f "$CS_ROOT/lib/common.sh" ]]; then
    source "$CS_ROOT/lib/common.sh"
else
    echo "Error: lib/common.sh not found"
    exit 1
fi

cs_cd_root

CLAUDE_DIR="$HOME/.claude"

echo -e "${CS_COLOR_BLUE}Installing oh-my-claude Plugin${CS_COLOR_RESET}"
echo "========================================"
echo ""

# Check if Claude Code CLI is available
if ! command -v claude &>/dev/null; then
    echo -e "${CS_COLOR_RED}Error: claude CLI not found${CS_COLOR_RESET}"
    echo "Please install Claude Code first:"
    echo "  https://code.anthropic.com/docs"
    exit 1
fi

# Check if uv is installed (required for oh-my-claude hooks)
if ! command -v uv &>/dev/null; then
    echo ""
    echo -e "${CS_COLOR_YELLOW}[1/3] Installing uv (required for oh-my-claude)...${CS_COLOR_RESET}"
    curl -LsSf https://astral.sh/uv/install.sh | sh
    echo -e "  ${CS_COLOR_GREEN}✓${CS_COLOR_RESET} uv installed"

    # Add uv to PATH for current session
    if [[ -f "$HOME/.local/bin/uv" ]]; then
        export PATH="$HOME/.local/bin:$PATH"
    fi
else
    echo -e "${CS_COLOR_GREEN}[1/3]${CS_COLOR_RESET} uv already installed"
fi

echo ""
echo -e "${CS_COLOR_BLUE}[2/3]${CS_COLOR_RESET} Adding oh-my-claude marketplace..."
# Add the marketplace
claude plugin marketplace add TechDufus/oh-my-claude &>/dev/null || {
    # If marketplace add fails, try alternative method
    echo -e "  ${CS_COLOR_YELLOW}⚠${CS_COLOR_RESET} Marketplace add failed, trying local clone..."
    TMP_DIR="/tmp/oh-my-claude-install"
    rm -rf "$TMP_DIR"
    git clone https://github.com/TechDufus/oh-my-claude "$TMP_DIR" &>/dev/null || {
        echo -e "  ${CS_COLOR_RED}✗${CS_COLOR_RESET} Failed to clone oh-my-claude"
        exit 1
    }
    claude plugin marketplace add "$TMP_DIR" &>/dev/null || {
        echo -e "  ${CS_COLOR_RED}✗${CS_COLOR_RESET} Failed to add marketplace"
        exit 1
    }
    rm -rf "$TMP_DIR"
}
echo -e "  ${CS_COLOR_GREEN}✓${CS_COLOR_RESET} Marketplace added"

echo ""
echo -e "${CS_COLOR_BLUE}[3/3]${CS_COLOR_RESET} Installing oh-my-claude plugin..."
# Install the plugin
claude plugin install oh-my-claude@oh-my-claude &>/dev/null || {
    echo -e "  ${CS_COLOR_RED}✗${CS_COLOR_RESET} Failed to install plugin"
    exit 1
}
echo -e "  ${CS_COLOR_GREEN}✓${CS_COLOR_RESET} Plugin installed"

echo ""
echo -e "${CS_COLOR_GREEN}========================================${CS_COLOR_RESET}"
echo -e "${CS_COLOR_GREEN}Installation Complete!${CS_COLOR_RESET}"
echo -e "${CS_COLOR_GREEN}========================================${CS_COLOR_RESET}"
echo ""
echo "oh-my-claude has been installed with the following features:"
echo ""
echo "  • Ultrawork mode - Add 'ultrawork' to any prompt for"
echo "    maximum parallel execution with intelligent subagent use"
echo ""
echo "  • Ultraresearch mode - Add 'ultraresearch' for deep"
echo "    research with multiple parallel queries"
echo ""
echo "  • Specialized agents:"
echo "    - git-commit-validator (validates commit messages)"
echo "    - pr-creation (automates PR creation)"
echo "    - worktree (git worktree automation)"
echo "    - debugger (systematic debugging)"
echo "    - tdd (test-driven development)"
echo "    - verification (evidence-based validation)"
echo "    - And more..."
echo ""
echo "  • Quality gates:"
echo "    - Context protection (delegates file reads to subagents)"
echo "    - Plan review (critic agent reviews plans before execution)"
echo "    - Pre-commit validation (git hooks)"
echo "    - Todo enforcement (reminds about incomplete tasks)"
echo ""
echo -e "${CS_COLOR_YELLOW}Important:${CS_COLOR_RESET}"
echo "  Restart Claude Code for hooks to activate"
echo ""
echo "Usage examples:"
echo "  claude 'fix all the type errors, ultrawork'"
echo "  claude 'ultraresearch best practices for API design'"
echo ""
echo "For more information:"
echo "  https://github.com/TechDufus/oh-my-claude"
echo ""
